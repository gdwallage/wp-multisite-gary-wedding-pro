# WordPress Theme .gitignore

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Node / npm (If you use build tools like Webpack/Gulp)
node_modules/
npm-debug.log
package-lock.json
yarn.lock

# Composer (If you use PHP dependencies)
vendor/
composer.lock

# IDE / Editor files
.idea/
.vscode/
*.swp
*.swo
*~

# Log files
*.log
debug.log

# Compiled CSS/JS (Optional, uncomment if you only want to track source files)
# css/style.css
# js/dist/
